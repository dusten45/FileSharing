<?xml version="1.0" encoding="utf-8"?>
<resources>
    <style name="Theme.FileSharing" parent="Theme.MaterialComponents.DayNight.NoActionBar">
        <item name="colorPrimary">@color/discord_blurple</item>
        <item name="colorPrimaryVariant">@color/discord_darkest</item>
        <item name="colorOnPrimary">@color/white</item>
        <item name="colorSecondary">@color/discord_green</item>
        <item name="colorOnSecondary">@color/white</item>
        <item name="android:colorBackground">@color/discord_dark</item>
        <item name="colorSurface">@color/discord_darker</item>
        <item name="colorOnSurface">@color/discord_text</item>
        <item name="android:windowBackground">@color/discord_dark</item>
        <item name="android:statusBarColor">@color/discord_darkest</item>
        <item name="android:navigationBarColor">@color/discord_darkest</item>
    </style>

    <style name="Theme.FileSharing.NoActionBar">
        <item name="windowActionBar">false</item>
        <item name="windowNoTitle">true</item>
    </style>

    <style name="Widget.FileSharing.Button" parent="Widget.MaterialComponents.Button">
        <item name="backgroundTint">@color/discord_blurple</item>
        <item name="android:textColor">@color/white</item>
        <item name="cornerRadius">4dp</item>
    </style>
</resources>
