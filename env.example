# Discord Webhook URL
# Discord 서버 → 채널 편집 → 연동 → 웹후크 → 새 웹후크 → URL 복사
DISCORD_WEBHOOK_URL=https://discord.com/api/webhooks/YOUR_ID/YOUR_TOKEN

# 파일 크기 기준 (MB). 이 값 이하면 Discord 직접 업로드, 초과면 Google Drive로 전환
SIZE_LIMIT_MB=10

# Google OAuth2 인증 파일 경로 (Google Cloud Console에서 다운로드)
GDRIVE_CREDENTIALS_FILE=credentials.json
